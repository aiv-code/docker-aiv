ourceOwner":"Admin","sourcePath":"/Hospital Demo/"}},"widgetId":"7dd7-wid-6008","aggregationInfo":{"metaData":[],"queryColumn":{},"sources":[],"orderBy":{"field":"","direction":""},"aggregation":[],"groupBy":{"fields":[]},"type":"","parameters":{},"metaFlag":false,"aggregate":false},"widgetProperties":{"hideInDesktop":false,"hideMenu":false,"hideInMobile":false,"hideDownloadIcon":false,"hideAnnotation":false,"hideFilterInfo":false,"hideInTablet":false,"doNotFilter":false,"hideAnalysis":false,"hideClearFilter":false,"autoRefreshEnabled":false},"widgetType":"customVisualization","widgetConfig":{"css":"    body {\r\n      background: linear-gradient(to right, #d1ccf7, #f1effd);\r\n      overflow: hidden;\r\n      font-family: Arial, sans-serif;\r\n    }\r\n    .header {\r\n      text-align: right;\r\n      margin: 20px;\r\n    }\r\n    .header span {\r\n      font-weight: bold;\r\n      color: #4e4e88;\r\n    }\r\n    .update-box {\r\n      display: inline-block;\r\n      padding: 3px 8px;\r\n      font-size: 14px;\r\n      border-radius: 3px;\r\n      color: #4e4e88;\r\n    }\r\n    .green-dot {\r\n      height: 8px;\r\n      width: 8px;\r\n      background-color: green;\r\n      border-radius: 50%;\r\n      display: inline-block;\r\n      margin-right: 6px;\r\n    }\r\n","js":"","html":"<!DOCTYPE html>\r\n<html lang=\"en\">\r\n<head>\r\n  <meta charset=\"UTF-8\">\r\n  <title>Welcome Guest<\/title>\r\n  \r\n<\/head>\r\n<body>\r\n\r\n  <div class=\"header\">\r\n<span style=\"color: #171717;\">Welcome, Guest!<\/span>\r\n    <br>\r\n    <div class=\"update-box\">\r\n      <span class=\"green-dot\"><\/span>\r\n      Last data updated: <span id=\"updateTime\"><\/span>\r\n    <\/div>\r\n  <\/div>\r\n\r\n  <script>\r\n    function formatDate(date) {\r\n      const day = String(date.getDate()).padStart(2, '0');\r\n      const month = String(date.getMonth() + 1).padStart(2, '0'); // months are 0-based\r\n      const year = date.getFullYear();\r\n      return `${day}/${month}/${year}`;\r\n    }\r\n\r\n    document.getElementById(\"updateTime\").textContent = formatDate(new Date());\r\n  <\/script>\r\n\r\n<\/body>\r\n<\/html>\r\n"},"dynamicView":false,"subTitle":"","subTitleStyle":{"padding":"0px","boxShadow":false,"backgroundColor":"#ffffff","borderColor":"#333333","color":"#333333","align":"left","enableborder":false,"borderTop":1,"borderLeft":1,"hide":false,"borderRight":1,"fontSize":12,"borderStyle":"solid","borderBottom":1,"fontWeight":"normal"},"name":"CustomVisualization Widget","iamTheParentDynamicViewWidget":false,"share":{"shareWith":{},"share":false},"style":{"boxShadow":false,"padding":"0px","backgroundColor":"#ffffff","margin":0,"useBackgroundImage":false,"boxShadowForBody":false,"enableborder":false,"zIndex":0},"titleStyle":{"padding":"0px","boxShadow":false,"backgroundColor":"#ffffff","borderColor":"#333333","color":"#333333","icon":false,"align":"left","enableborder":false,"borderTop":1,"borderLeft":1,"hide":true,"borderRight":1,"fontSize":12,"borderStyle":"solid","borderBottom":1,"fontWeight":"normal"},"position":{"tablet":{"x":0,"width":320,"y":0,"height":270},"desktop":{"x":227,"width":1172,"y":-7,"height":704},"mobile":{"x":0,"width":324,"y":0,"height":330}},"id":"copy-move-widget-5761_widget5287","locked":false},"7157-wid-1ed6":{"widgetName":"Total Patients by Gender and Age","heavyDataProcessing":false,"sources":{"44236":{"sourceId":44236,"superSourceType":"NormalDataset","sourceType":"ds","sourceParams":{},"sourceName":"Hospital_ER_Analytics_Dataset","sourceOwner":"Admin","sourcePath":"/Hospital Demo/"}},"widgetId":"7157-wid-1ed6","aggregationInfo":{"metaData":[],"queryColumn":{},"sources":[],"orderBy":{"field":"","direction":""},"aggregation":[],"groupBy":{"fields":[]},"type":"","parameters":{},"metaFlag":false,"aggregate":false},"widgetProperties":{"hideInDesktop":false,"hideMenu":false,"hideInMobile":false,"hideDownloadIcon":false,"hideAnnotation":false,"hideFilterInfo":false,"hideInTablet":false,"doNotFilter":fal