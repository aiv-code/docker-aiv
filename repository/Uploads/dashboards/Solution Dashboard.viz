olor":"#ffffff","borderColor":"#333333","color":"#333333","icon":false,"align":"left","enableborder":false,"borderTop":1,"borderLeft":1,"hide":true,"borderRight":1,"fontSize":12,"borderStyle":"solid","borderBottom":1,"fontWeight":"normal"},"position":{"tablet":{"x":0,"width":320,"y":0,"height":270},"desktop":{"x":240,"width":153.9247863247863,"y":100,"height":162.86086092644555},"mobile":{"x":0,"width":324,"y":0,"height":330}},"extraLabel":{"padding":"0px","isExtraLabel":false}},"dd0f-wid-d79d":{"widgetName":"Race","heavyDataProcessing":false,"sources":{"44236":{"sourceId":44236,"superSourceType":"NormalDataset","sourceType":"ds","sourceParams":{},"sourceName":"Hospital_ER_Analytics_Dataset","sourceOwner":"Admin","sourcePath":"/Hospital Demo/"}},"widgetId":"dd0f-wid-d79d","aggregationInfo":{"metaData":[],"queryColumn":{},"sources":[],"orderBy":{"field":"","direction":""},"aggregation":[],"groupBy":{"fields":[]},"type":"","parameters":{},"metaFlag":false,"aggregate":false},"widgetProperties":{"hideInDesktop":false,"hideMenu":false,"hideInMobile":false,"hideDownloadIcon":false,"hideAnnotation":false,"hideFilterInfo":false,"hideInTablet":false,"doNotFilter":false,"hideAnalysis":true,"hideClearFilter":false,"autoRefreshEnabled":false},"widgetType":"customVisualization","widgetConfig":{"css":"body {\r\n      font-family: 'Inter', sans-serif;\r\n      background: #f4f4fc;\r\n      padding: 20px;\r\n      overflow: hidden;\r\n    }\r\n\r\n    .race-card {\r\n\r\n      max-width: 420px;\r\n      margin: auto;\r\n    }\r\n\r\n    .race-card h2 {\r\n      font-size: 1.4rem;\r\n      font-weight: 700;\r\n      margin-bottom: 16px;\r\n      text-align: left;\r\n      color: #333;\r\n    }\r\n\r\n    .race-row {\r\n      display: flex;\r\n      justify-content: space-between;\r\n      align-items: center;\r\n      margin-bottom: 6px;\r\n    }\r\n\r\n    .race-label {\r\n      font-size: 0.9rem;\r\n      color: #333;\r\n      flex: 1.5;\r\n    }\r\n\r\n    .race-count {\r\n      font-weight: 600;\r\n      font-size: 0.9rem;\r\n      flex: 0.8;\r\n      text-align: right;\r\n    }\r\n\r\n    .race-percent {\r\n      font-size: 0.85rem;\r\n      color: #666;\r\n      flex: 0.7;\r\n      text-align: right;\r\n    }\r\n\r\n    .bar-container {\r\n      height: 8px;\r\n      background-color: #e0e0e0;\r\n      border-radius: 5px;\r\n      overflow: hidden;\r\n      margin-top: 4px;\r\n      margin-bottom: 10px;\r\n    }\r\n\r\n    .bar-fill {\r\n      height: 100%;\r\n      background-color: #6a5acd;\r\n      width: 0%;\r\n      transition: width 0.5s ease;\r\n    }","js":"    const dataset = {{dataset::Hospital_ER_Analytics_Dataset}};\r\n\r\n    document.addEventListener(\"DOMContentLoaded\", () => {\r\n      const data = Array.isArray(dataset) ? dataset : [];\r\n      const counts = {};\r\n      let total = 0;\r\n\r\n      data.forEach(row => {\r\n        const race = row[\"Race\"];\r\n        if (race) {\r\n          counts[race] = (counts[race] || 0) + 1;\r\n          total++;\r\n        }\r\n      });\r\n\r\n      const container = document.getElementById(\"race-container\");\r\n\r\n      Object.entries(counts)\r\n        .sort(([, a], [, b]) => b - a) // sort by count descending\r\n        .forEach(([race, count]) => {\r\n          const percent = ((count / total) * 100).toFixed(1);\r\n\r\n          const row = document.createElement(\"div\");\r\n          row.className = \"race-row\";\r\n          row.innerHTML = `\r\n            <div class=\"race-label\">${race}<\/div>\r\n            <div class=\"race-count\">${count}<\/div>\r\n            <div class=\"race-percent\">${percent}%<\/div>\r\n          `;\r\n\r\n          const barContainer = document.createElement(\"div\");\r\n          barContainer.className = \"bar-container\";\r\n\r\n          const barFill = document.createElement(\"div\");\r\n          barFill.className = \"bar-fill\";\r\n          barFill.style.width = `${percent}%`;\r\n\r\n          barContainer.appendChild(barFill);\r\n          container.appendChild(row);\r\n          container.appendChild(barContainer);\r\n        });\r\n    });\r\n","html":"\r\n<!DOCTYPE html>\r\n<html lang=\"en\">\r\n<head>\r\n  <meta charset=\"UTF-8\" />\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"/>\r\n  <title>Race Distribution<\/title>\r\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap\" rel=\"stylesheet\">\r\n\r\n<\/head>\r\n<body>\r\n\r\n  <div class=\"race-card\">\r\n    <div id=\"race-container\"><\/div>\r\n  <\/div>\r\n\r\n\r\n<\/body>\r\n<\/html>\r\n\r\n\r\n\r\n"},"dynamicView":false,"subTitle":"","subTitleStyle":{"padding":"0px","boxShadow":false,"backgroundColor":"#ffffff","borderColor":"#333333","color":"#333333","align":"left","enableborder":false,"borderTop":1,"borderLeft":1,"hide":false,"borderRight":1,"fontSize":12,"borderStyle":"solid","borderBottom":1,"fontWeight":"normal"},"name":"CustomVisualization Widget","iamTheParentDynamicViewWidget":false,"share":{"shareWith":{},"share":false},"style":{"boxShadow":true,"padding":"0px","backgroundColor":"#f4f4fc","borderColor":"#ffffff","margin":0,"useBackgroundImage":false,"boxShadowForBody":false,"boxShadowProperties":"0px 4px 6px rgba(0, 0, 0, 0.1)","enableborder":true,"borderTop":"1","borderTopLeftRadius":"15","borderLeft":"1","borderRadius":"15","borderBottomLeftRadius":"15","borderRight":"1","borderBottomRightRadius":"15","borderTopRightRadius":"15","borderStyle":"solid","borderBottom":"1","zIndex":0},"titleStyle":{"padding":"0px","boxShadow":false,"backgroundColor":"#f4f4fc","borderColor":"#333333","color":"#7a7aa7","icon":false,"align":"center","enableborder":false,"borderTop":1,"borderLeft":1,"hide":false,"borderRight":1,"fontSize":"16","borderStyle":"solid","borderBottom":1,"fontWeight":"bold"},"position":{"tablet":{"x":0,"width":320,"y":0,"height":270},"desktop":{"x":988.0615384615385,"width":388.6769230769231,"y":347.81538461538463,"height":306.82051282051293