et":false,"doNotFilter":false,"hideAnalysis":true,"autoRefreshEnabled":false,"hideInMobile":false,"refreshIntervalUnit":"seconds","hideDownloadIcon":false,"hideForecastAndPredict":false,"hideFilterInfo":false,"refreshIntervalValue":5,"hideInsights":true,"hideClearFilter":false,"disableAutoLinkFilter":false},"widgetType":"customVisualization","popupView":false,"sameLocationWidgetLinkId":[],"name":"CustomVisualization Widget","style":{"boxShadow":false,"borderColor":"#333333","backgroundImage":"","backgroundOpacity":"1","borderTop":1,"borderLeft":1,"borderBottomRightRadius":5,"backgroundSize":"cover","borderTopRightRadius":5,"backgroundPosition":"center","borderStyle":"solid","borderBottom":1,"zIndex":"101","padding":"5px","backgroundColor":"","backgroundAttachment":"scroll","margin":0,"useBackgroundImage":false,"boxShadowProperties":"0px 4px 6px rgba(0, 0, 0, 0.1)","enableborder":false,"borderTopLeftRadius":5,"borderBottomLeftRadius":5,"borderRight":1,"position":"right","backgroundRepeat":"no-repeat"},"sameLocationParentWidgetLinkId":"","position":{"tablet":{"x":20,"width":400,"y":20,"height":300},"desktop":{"x":235,"width":107,"y":6,"height":88},"mobile":{"x":20,"width":400,"y":20,"height":300}},"extraLabel":{"padding":"5px","isExtraLabel":false,"widgetId":"","link":"","label":"Hyperlink","position":"right","type":"hyperlink"},"sameLocationChildWidgetLinkId":""},"3fd8-wid-a621":{"widgetName":"CustomVisualization Widget","heavyDataProcessing":false,"sources":{},"widgetId":"3fd8-wid-a621","aggregationInfo":{"metaData":[],"queryColumn":{},"sources":[],"orderBy":{"field":"","direction":""},"aggregation":[],"groupBy":{"fields":[]},"type":"","parameters":{},"metaFlag":false,"aggregate":false},"widgetProperties":{"hideInDesktop":false,"hideMenu":false,"hideAnnotation":false,"hideInTablet":false,"doNotFilter":false,"hideAnalysis":true,"autoRefreshEnabled":false,"hideInMobile":false,"hideDownloadIcon":false,"hideFilterInfo":false,"hideInsights":true,"hideClearFilter":false,"disableAutoLinkFilter":false},"widgetType":"customVisualization","widgetConfig":{"css":" body {\r\n      margin: 0;\r\n      font-family: 'Roboto', Arial, Helvetica, sans-serif;\r\n         background: linear-gradient(to right, #d1ccf7, #f1effd);\r\n      overflow: hidden;\r\n    }\r\n\r\n    .sidebar {\r\n      height: 100vh;\r\n      width: 200px;\r\n      background: linear-gradient(to bottom right, #6c63b5, #7f7acf);\r\n      color: white;\r\n      display: flex;\r\n      flex-direction: column;\r\n      align-items: center;\r\n      padding-top: 28px;\r\n      border-radius: 30px;\r\n      margin-left: 9px;\r\n      box-shadow: 3px 0 10px rgba(0, 0, 0, 0.1);\r\n    }\r\n\r\n    .logo {\r\n      width: 50px;\r\n      margin-bottom: 10px;\r\n    }\r\n\r\n    .brand {\r\n      font-weight: bold;\r\n      margin-bottom: 20px;\r\n    }\r\n\r\n    .section-title {\r\n      margin-top: 22px;\r\n      margin-bottom: 5px;\r\n      font-size: 13px;\r\n      font-weight: bold;\r\n      color: #fff;\r\n      text-transform: uppercase;\r\n      width: 85%;\r\n      text-align: left;\r\n    }\r\n\r\n    .section-divider {\r\n      width: 85%;\r\n      border-top: 2px solid #eee;\r\n      margin-bottom: 10px;\r\n    }\r\n\r\n    .menu {\r\n      width: 100%;\r\n      display: flex;\r\n      flex-direction: column;\r\n      align-items: center;\r\n    }\r\n\r\n    .menu-item {\r\n      width: 80%;\r\n      background-color: rgba(255, 255, 255, 0.1);\r\n      padding: 10px;\r\n      border-radius: 10px;\r\n      margin-bottom: 10px;\r\n      display: flex;\r\n      align-items: center;\r\n      color: white;\r\n      cursor: pointer;\r\n      transition: background 0.3s;\r\n    }\r\n\r\n    .menu-item:hover {\r\n      background-color: rgba(255, 255, 255, 0.2);\r\n    }\r\n\r\n    .menu-item i {\r\n      margin-right: 10px;\r\n    }\r\n\r\n    img {\r\n      height: 32px;\r\n      width: auto;\r\n      padding: 6px;\r\n    }\r\n\r\n    .profile {\r\n      margin-top: auto;\r\n      margin-bottom: 95px;\r\n      text-align: center;\r\n    }\r\n\r\n    .profile-icons {\r\n      display: flex;\r\n      gap: 12px;\r\n      justify-content: center;\r\n    }\r\n\r\n    .profile p {\r\n      margin-top: 10px;\r\n      color: #ffffff;\r\n      font-size: 12px;\r\n    }","js":"","html":"\r\n<!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n  <meta charset=\"UTF-8\" />\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\r\n  <title>Sidebar Dashboard<\/title>\r\n  <link href=\"https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap\" rel=\"stylesheet\" />\r\n  <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\" />\r\n  <script src=\"https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js\"><\/script>\r\n  <script src=\"https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js\"><\/script>\r\n\r\n \r\n<\/head>\r\n\r\n<body>\r\n\r\n  <div class=\"sidebar\">\r\n    <img class=\"logo\" src=\"https://img.icons8.com/ios-filled/50/ffffff/caduceus.png\" alt=\"Logo\" />\r\n    <div class=\"brand\">RWFD<\/div>\r\n\r\n    <div class=\"section-title\">NAVIGATION<\/div>\r\n    <div class=\"section-divider\"><\/div>\r\n\r\n    <div class=\"menu\">\r\n      <div class=\"menu-item\" onclick=\"changeTab(0)\">\r\n        <i class=\"fas fa-home\"><\/i>\r\n        <span>Summary<\/span>\r\n      <\/div>\r\n      <div class=\"menu-item\" onclick=\"changeTab(1)\">\r\n        <i class=\"fas fa-calendar-alt\"><\/i>\r\n        <span>Visits<\/span>\r\n      <\/div>\r\n    <\/div>\r\n\r\n    <div class=\"section-title\">EXPORT<\/div>\r\n    <div class=\"section-divider\"><\/div>\r\n\r\n    <div class=\"menu\">\r\n      <div class=\"menu-item\" onclick=\"exportAsImage()\">\r\n        <i class=\"fas fa-image\"><\/i>\r\n        <span>Image<\/span>\r\n      <\/div>\r\n      <div class=\"menu-item\" onclick=\"exportAsPDF()\">\r\n        <i class=\"fas fa-file-pdf\"><\/i>\r\n        <span>PDF<\/span>\r\n      <\/div>\r\n    <\/div>\r\n  \r\n    <div class=\"profile\">\r\n      <div class=\"profile-icons\">\r\n        <!-- <a href=\"https://www.aivhub.com/\" target=\"_blank\" title=\"Download AIV\"> -->\r\n          <img src=\"https://img.icons8.com/ios-filled/30/ffffff/internet.png\" alt=\"Internet\" />\r\n        <\/a>\r\n        <!-- <a href=\"https://github.com/aiv-code/docker-aiv\" target=\"_blank\" title=\"GitHub\"> -->\r\n          <img src=\"https://img.icons8.com/ios-filled/30/ffffff/github.png\" alt=\"GitHub\" />\r\n        <\/a>\r\n        <!-- <a href=\"https://www.linkedin.com/company/aivhub/\" target=\"_blank\" title=\"LinkedIn\"> -->\r\n          <img src=\"https://img.icons8.com/ios-filled/30/ffffff/linkedin.png\" alt=\"LinkedIn\" />\r\n        <\/a>\r\n      <\/div>\r\n      <p>Designed by AIVHUB<\/p>\r\n    <\/div>\r\n  <\/div>\r\n\r\n   <script>\r\n    function changeTab(tabIndex) {\r\n      if (window.parent && window.parent.viz) {\r\n        window.parent.viz.changeTab(tabIndex);\r\n      }\r\n    }\r\n\r\n    function exportAsImage() {\r\n      html2canvas(document.body).then(canvas => {\r\n        const link = document.createElement(\"a\");\r\n        link.download = \"dashboard.png\";\r\n        link.href = canvas.toDataURL(\"image/png\");\r\n        link.click();\r\n      });\r\n    }\r\n\r\n    async function exportAsPDF() {\r\n      const { jsPDF } = window.jspdf;\r\n      html2canvas(document.body).then(canvas => {\r\n        const imgData = canvas.toDataURL(\"image/png\");\r\n        const pdf = new jsPDF({\r\n          orientation: \"portrait\",\r\n          unit: \"px\",\r\n          format: [canvas.width, canvas.height]\r\n        });\r\n        pdf.addImage(imgData, \"PNG\", 0, 0, canvas.width, canvas.height);\r\n        pdf.save(\"dashboard.pdf\");\r\n      });\r\n    }\r\n  <\/script>\r\n\r\n<\/body>\r\n\r\n<\/html>\r\n\r\n   "},"dynamicView":false,"subTitle":"","subTitleSt