aData":[],"queryColumn":{},"sources":[],"orderBy":{"field":"","direction":""},"aggregation":[],"groupBy":{"fields":[]},"type":"","parameters":{},"metaFlag":false,"aggregate":false},"widgetConfig":{"css":".tab-nav {\r\n  display: flex;\r\n  gap: 10px;\r\n  align-items: center;\r\n}\r\n\r\n/* Arrow button */\r\n.tab-arrow {\r\n  width: 38px;\r\n  height: 30px;\r\n  border: none;\r\n  border-radius: 6px;\r\n  cursor: pointer;\r\n\r\n  background: linear-gradient(\r\n    135deg,\r\n    #bddde4,\r\n    #9ec6f3,\r\n    #9fb3df\r\n  );\r\n\r\n  color: #2b3a55;\r\n  font-size: 15px;\r\n  font-weight: 600;\r\n\r\n  box-shadow: 0 3px 8px rgba(158, 198, 243, 0.35);\r\n  transition: transform 0.2s ease, box-shadow 0.2s ease;\r\n}\r\n\r\n/* Hover */\r\n.tab-arrow:hover {\r\n  transform: translateY(-1px);\r\n  box-shadow: 0 5px 12px rgba(158, 198, 243, 0.45);\r\n}\r\n\r\n/* Click */\r\n.tab-arrow:active {\r\n  transform: translateY(0);\r\n  box-shadow: 0 2px 6px rgba(158, 198, 243, 0.3);\r\n}\r\n","js":"// TOTAL number of tabs (update only this if tabs change)\r\nconst LAST_TAB_INDEX = 2;\r\n\r\n// Core tab switch (your original logic preserved)\r\nfunction goToTab(index) {\r\n  try {\r\n    if (\r\n      window.parent &&\r\n      window.parent.viz &&\r\n      typeof window.parent.viz.changeTab === \"function\"\r\n    ) {\r\n      window.parent.viz.changeTab(index);\r\n      console.log(\"Switched to tab:\", index);\r\n    } else {\r\n      console.warn(\"viz.changeTab not available\");\r\n    }\r\n  } catch (e) {\r\n    console.error(\"Error switching tab:\", e);\r\n  }\r\n}\r\n\r\n// Universal navigation handler (works on ALL tabs)\r\ndocument.addEventListener(\"click\", function (e) {\r\n  const btn = e.target.closest(\".tab-arrow\");\r\n  if (!btn) return;\r\n\r\n  const current = Number(btn.dataset.current);\r\n  const direction = btn.dataset.dir;\r\n\r\n  if (Number.isNaN(current)) return;\r\n\r\n  if (direction === \"prev\" && current > 0) {\r\n    goToTab(current - 1);\r\n  }\r\n\r\n  if (direction === \"next\" && current < LAST_TAB_INDEX) {\r\n    goToTab(current + 1);\r\n  }\r\n});\r\n\r\nconsole.log(\"Global tab navigation loaded\");\r\n","html":"<div class=\"tab-nav\">\r\n  <button class=\"tab-arrow disabled\"\r\n          data-dir=\"prev\"\r\n          data-current=\"0\">&#x25C0;<\/button>\r\n\r\n  <button class=\"tab-arrow\"\r\n          data-dir=\"next\"\r\n          data-current=\"0\">&#x25B6;<\/button>\r\n<\/div>\r\n"},"dynamicView":false,"subTitle":"","subTitleStyle":{"padding":"0px","boxShadow":false,"backgroundColor":"#ffffff","borderColor":"#333333","color":"#333333","align":"left","enableborder":false,"borderTop":1,"borderLeft":1,"hide":false,"borderRight":1,"fontSize":12,"borderStyle":"solid","borderBottom":1,"fontWeight":"normal"},"sameLocation":false,"iamTheParentDynamicViewWidget":false,"share":{"shareWith":{},"share":false},"titleStyle":{"padding":"0px","boxShadow":false,"backgroundColor":"#ffffff","borderColor":"#333333","color":"#333333","icon":false,"align":"left","enableborder":false,"borderTop":1,"borderLeft":1,"hide":true,"borderRight":1,"fontSize":12,"borderStyle":"solid","borderBottom":1,"fontWeight":"normal"},"popupWidgetLinkId":"","locked":false,"widgetId":"ad3f-wid-33c0","widgetProperties":{"hideInDesktop":false,"hideMenu":false,"hideAnnotation":false,"hideInTablet":false,"doNotFilter":false,"hideAnalysis":true,"autoRefreshEnabled":false,"hideInMobile":false,"hideDownloadIcon":false,"hideFilterInfo":false,"hideInsights":true,"hideClearFilter":false,"disableAutoLinkFilter":false},"widgetType":"customVisualization","popupView":false,"sameLocationWidgetLinkId":[],"name":"CustomVisualization Widget","style":{"boxShadow":false,"padding":"5px","backgroundColor":"#ffffff","margin":0,"useBackgroundImage":false,"enableborder":false,"zIndex":267},"sameLocationParentWidgetLinkId":"","position":{"tablet":{"x":20,"width":400,"y":20,"height":300},"desktop":{"x":157,"width":143,"y":9,"height":70},"mobile":{"x":20,"wid