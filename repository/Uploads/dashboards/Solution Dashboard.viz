or":"#eef2ff","backgroundAttachment":"scroll","useBackgroundImage":false,"backgroundImage":"","backgroundOpacity":"1","backgroundSize":"cover","desktopDesign":{"designWidth":1370,"scaleMode":"actualSize","designHeight":793,"type":"custom"},"backgroundPosition":"center","backgroundRepeat":"no-repeat","mobileDesign":{"designWidth":375,"scaleMode":"actualSize","designHeight":667},"tabletDesign":{"designWidth":768,"scaleMode":"fitToPage","designHeight":1024}},"widgetList":{"widget_695c_aiv_viz_e5b1":{"widgetName":"CustomVisualization Widget","heavyDataProcessing":false,"sources":{},"aggregationInfo":{"metaData":[],"queryColumn":{},"sources":[],"orderBy":{"field":"","direction":""},"aggregation":[],"groupBy":{"fields":[]},"type":"","parameters":{},"metaFlag":false,"aggregate":false},"widgetConfig":{"css":"* {\r\n  margin: 0;\r\n  padding: 0;\r\n  box-sizing: border-box;\r\n  font-family: 'Inter', sans-serif;\r\n}\r\n\r\nbody {\r\n  background: linear-gradient(135deg, #f8fafc, #eef2ff);\r\n  padding: 60px;\r\n  color: #1e293b;\r\n  overflow: hidden;\r\n}\r\n\r\n/* HEADER */\r\n.header {\r\n  text-align: center;\r\n  margin-bottom: 60px;\r\n}\r\n\r\n.header h1 {\r\n  margin-bottom: 15px;\r\n   font-size: 32px;\r\n  font-weight: 600;\r\n  background: linear-gradient(90deg, #334155, #6366f1);\r\n  -webkit-background-clip: text;\r\n  -webkit-text-fill-color: transparent;\r\n  letter-spacing: 0.3px;\r\n}\r\n\r\n.header p {\r\n  font-size: 16px;\r\n  color: #64748b;\r\n}\r\n\r\n.header a {\r\n  color: #2563eb;\r\n  font-weight: 600;\r\n  text-decoration: none;\r\n  cursor: pointer;\r\n}\r\n\r\n.header a:hover {\r\n  text-decoration: underline;\r\n}\r\n\r\n/* GRID */\r\n.grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));\r\n  gap: 35px;\r\n}\r\n\r\n/* CARD */\r\n.card {\r\n  background: rgba(255,255,255,0.7);\r\n  backdrop-filter: blur(10px);\r\n  border-radius: 18px;\r\n  padding: 30px;\r\n  position: relative;\r\n  overflow: hidden;\r\n  transition: all 0.35s ease;\r\n  box-shadow: 0 10px 25px rgba(0,0,0,0.05);\r\n  border: 1px solid rgba(0,0,0,0.05);\r\n}\r\n\r\n.card:hover {\r\n  transform: translateY(-6px);\r\n  box-shadow: 0 12px 28px rgba(0,0,0,0.08);\r\n}\r\n\r\n.card h3 {\r\n  font-size: 22px;\r\n  margin-bottom: 12px;\r\n}\r\n\r\n.card p {\r\n  font-size: 14px;\r\n  color: #475569;\r\n  margin-bottom: 25px;\r\n  line-height: 1.6;\r\n}\r\n\r\n/* BUTTON */\r\n.card a {\r\n  display: inline-block;\r\n  padding: 10px 22px;\r\n  border-radius: 8px;\r\n  background: #eef2ff;\r\n  color: #4f46e5;\r\n  font-size: 14px;\r\n  font-weight: 500;\r\n  text-decoration: none;\r\n  border: 1px solid #c7d2fe;\r\n  transition: all 0.25s ease;\r\n}\r\n\r\n.card a:hover {\r\n  background: #e0e7ff;\r\n}\r\n/* ICON */\r\n.card-icon {\r\n  position: absolute;\r\n  bottom: 20px;\r\n  right: 20px;\r\n  font-size: 50px;\r\n  transition: 0.3s ease;\r\n}\r\n\r\n.card:hover .card-icon {\r\n  transform: scale(1.2);\r\n}\r\n\r\n.modal {\r\n  display: none;\r\n  position: fixed;\r\n  z-index: 9999;\r\n  left: 0;\r\n  top: 0;\r\n  width: 100%;\r\n  height: 100%;\r\n  background: rgba(0,0,0,0.8);\r\n  justify-content: center;\r\n  align-items: center;\r\n}\r\n\r\n.modal-content {\r\n  position: relative;\r\n  width: 80%;\r\n  max-width: 800px;\r\n}\r\n\r\n.modal iframe {\r\n  width: 100%;\r\n  height: 450px;\r\n  border-radius: 8px;\r\n}\r\n\r\n.close-btn {\r\n  position: absolute;\r\n  top: -35px;\r\n  right: 0;\r\n  font-size: 30px;\r\n  color: white;\r\n  cursor: pointer;\r\n}\r\n\r\n\r\n/* RESPONSIVE */\r\n@media(max-width:768px){\r\n  body { padding: 30px; }\r\n  .header h1 { font-size: 26px; }\r\n}\r\n","js":"  function openVideo(event) {\r\n      event.preventDefault();\r\n    \r\n      const modal = document.getElementById(\"videoModal\");\r\n      const iframe = document.getElementById(\"videoFrame\");\r\n    \r\n      iframe.src = \"https://www.youtube.com/embed/_JBCZv0gKpM?autoplay=1&rel=0&list=PLfw3oY-1kQv3c9iphGX5WVZCYS0eXXib7\";\r\n    \r\n      modal.style.display = \"flex\";\r\n    }\r\n    \r\n    function closeVideo() {\r\n      const modal = document.getElementById(\"videoModal\");\r\n      const iframe = document.getElementById(\"videoFrame\");\r\n    \r\n      iframe.src = \"\"; \r\n      modal.style.display = \"none\";\r\n    }\r\n    \r\n    window.onclick = function(event) {\r\n      const modal = document.getElementById(\"videoModal\");\r\n      if (event.target === modal) {\r\n        closeVideo();\r\n      }\r\n    }\r\n\r\n    \r\n  function layer(index) {\r\n    window.parent.viz.changeLayer('layer' + index, 0);\r\n  }","html":"<!DOCTYPE html>\r\n<html lang=\"en\">\r\n<head>\r\n<meta charset=\"UTF-8\">\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n<title>AIV Solution Dashboards<\/title>\r\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap\" rel=\"stylesheet\">\r\n\r\n\r\n<\/head>\r\n\r\n<body>\r\n\r\n<div class=\"header\">\r\n  <h1>Welcome to AIV Solution Dashboards<\/h1>\r\n  <p>\r\n    Explore interactive dashboards by selecting a category below.\r\n    You can also create your own dashboard in minutes.\r\n    <a href=\"#\" onclick=\"openVideo(event)\" class=\"video-link\">\r\n      Watch a video\r\n    <\/a>\r\n  <\/p>\r\n<\/div>\r\n\r\n\r\n<div class=\"grid\">\r\n\r\n  <div class=\"card\">\r\n    <h3>Retail<\/h3>\r\n    <p>Analyze customer demand, sales trends and inventory insights to improve decisions.<\/p>\r\n  <a href=\"#\" onclick=\"layer(7)\">View Details<\/a>\r\n    <div class=\"card-icon\">🛍️<\/div>\r\n  <\/div>\r\n\r\n  <div class=\"card\">\r\n    <h3>Healthcare<\/h3>\r\n    <p>Gain deeper insights into hospital management and cost optimization.<\/p>\r\n      <a href=\"#\" onclick=\"layer(4); return false;\">View Details<\/a>\r\n    <div class=\"card-icon\">🏥<\/div>\r\n  <\/div>\r\n\r\n  <div class=\"card\">\r\n    <h3>Manufacturing<\/h3>\r\n    <p>Improve production efficiency and reduce operational costs.<\/p>\r\n         <a href=\"#\" onclick=\"layer(2); return false;\">View Details<\/a>\r\n    <div class=\"card-icon\">🏭<\/div>\r\n  <\/div>\r\n\r\n  <div class=\"card\">\r\n    <h3>Logistics<\/h3>\r\n    <p>Optimize supply chain and ensure smooth delivery operations.<\/p>\r\n            <a href=\"#\" onclick=\"layer(6); return false;\">View Details<\/a>\r\n    <div class=\"card-icon\">🚚<\/div>\r\n  <\/div>\r\n\r\n  <div class=\"card\">\r\n    <h3>Energy & Utility<\/h3>\r\n    <p>Identify emerging opportunities and enhance operational efficiency.<\/p>\r\n             <a href=\"#\" onclick=\"layer(5); return false;\">View Details<\/a>\r\n    <div class=\"card-icon\">⚡<\/div>\r\n  <\/div>\r\n\r\n  <div class=\"card\">\r\n    <h3>Education<\/h3>\r\n    <p>Empower institutions with insights into attendance and performance.<\/p>\r\n            <a href=\"#\" onclick=\"layer(3); return false;\">View Details<\/a>\r\n    <div class=\"card-icon\">🎓<\/div>\r\n  <\/div>\r\n\r\n<\/div>\r\n\r\n<!-- VIDEO MODAL -->\r\n<div class=\"modal\" id=\"videoModal\">\r\n  <div class=\"modal-content\">\r\n    <span class=\"close-btn\" onclick=\"closeVideo()\">&times;<\/span>\r\n    <iframe id=\"videoFrame\" \r\n            src=\"\" \r\n            frameborder=\"0\" \r\n            allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" \r\n            allowfullscreen>\r\n    <\/iframe>\r\n  <\/div>\r\n<\/div>\r\n<\/body>\r\n<\/html>\r\n"},"dynamicView":false,"subTitle":"","subTitleStyle":{"padding":"0px","boxShadow":false,"backgroundColor":"#ffffff","borderColor":"#333333","color":"#333333","boxShadowProperties":"0px 4px 6px rgba(0, 0, 0, 0.1)","align":"left","enableborder":false,"borderTop":1,"borderLeft":1,"hide":false,"borderRight":1,"fontSize":12,"borderStyle":"solid","borderBottom":1,"fontWeight":"normal"},"sameLocation":false,"iamTheParentDynamicViewWidget":false,"share":{"shareWith":{},"share":false},"ti