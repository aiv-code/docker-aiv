<?xml version="1.0" encoding="UTF-8" standalone="no"?><DATASOURCE sourcetype="parquet"><DATASET existingFileCategory="DATASETS" existingFileId="66047" existingFileName="Education_dataset" existingFileOwner="Admin" existingFilePath="/education/" existingFileType="parquet" name="Education_firstgeneration" type="NormalDataset"><QUERY>SELECT
COUNT(CASE
WHEN First_Generation = 'Yes'
THEN Application_ID
END) * 100.0
/
